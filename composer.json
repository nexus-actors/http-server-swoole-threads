{
    "name": "nexus-actors/http-server-swoole-threads",
    "description": "Thread-mode HTTP server built on Swoole 6 native SWOOLE_THREAD; cross-thread pool-singleton actors via WorkerNode.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.5.7",
        "ext-swoole": ">=6.2.1",
        "nexus-actors/core": "^0.1",
        "nexus-actors/http": "^0.1",
        "nexus-actors/http-server-swoole": "^0.1",
        "nexus-actors/http-ws": "^0.1",
        "nexus-actors/runtime": "^0.1",
        "nexus-actors/runtime-swoole": "^0.1",
        "nexus-actors/worker-pool": "^0.1",
        "nexus-actors/worker-pool-swoole": "^0.1",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Monadial\\Nexus\\Http\\Server\\Swoole\\Threads\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Monadial\\Nexus\\Http\\Server\\Swoole\\Threads\\Tests\\": "tests/"
        }
    }
}
